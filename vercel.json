{
  "crons": [
    {
      "path": "/api/cron/weekly-report",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/improvement-digest",
      "schedule": "0 */6 * * *"
    }
  ],
  "functions": {
    "app/api/qbank/route.ts": {
      "maxDuration": 30
    },
    "app/api/qbank/image/route.ts": {
      "maxDuration": 45
    },
    "app/api/cron/**": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
