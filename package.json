{
  "name": "scholorhaab",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack && node tools/strip-next-traces.mjs",
    "start": "next start",
    "lint": "eslint",
    "rebuild:qbank-concepts": "node scripts/rebuild_qbank_concept_index.mjs",
    "compile:qbank-questions": "node scripts/compile_qbank_question_bank.mjs",
    "build:qbank-ao-level": "node scripts/build_ao_level_qbank_supplement.mjs",
    "verify:qbank-ao-level": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/verify_ao_level_qbank_supplement.mjs",
    "build:qbank-exam-chunks": "python scripts/build_qbank_exam_pdf_chunks.py",
    "verify:qbank-exam-chunks": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/verify_qbank_exam_pdf_chunks.mjs",
    "validate:qbank-jsonl": "node scripts/validate_qbank_jsonl.mjs",
    "test:ai-service": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/test_ai_service_reliability.mjs",
    "test:learning-system": "node scripts/verify_learning_system.mjs",
    "test:intelligence-layer": "node scripts/verify_intelligence_layer.mjs",
    "test:dashboard-system": "node scripts/verify_dashboard_system.mjs",
    "test:regressions": "node scripts/run_regression_checks.mjs",
    "eval:rag": "ts-node-script --transpile-only scripts/rag_eval.ts",
    "qa": "ts-node --transpile-only scripts/auto_qa.ts",
    "qa:fix": "ts-node --transpile-only scripts/auto_qa.ts --auto-fix",
    "qa:train": "ts-node --transpile-only scripts/feedback_trainer.ts",
    "qa:full": "npm run qa:fix && npm run qa:train",
    "proof:coverage": "node scripts/generate_coverage_reports.mjs",
    "proof:taxonomy": "node scripts/generate_taxonomy_outputs.mjs",
    "proof:release": "node scripts/generate_release_governance_docs.mjs",
    "proof:all": "npm run proof:coverage -- --update-baseline && npm run proof:taxonomy && npm run proof:release",
    "proof:validate": "node scripts/validate_coverage_matrix.mjs",
    "predeploy:check": "node scripts/predeploy_check.mjs",
    "prod:check": "ts-node --transpile-only scripts/prod_ready_check.ts",
    "perf:smoke": "node scripts/load_test_smoke.mjs",
    "deploy:verify": "node scripts/deploy_verify.mjs",
    "test:tutor-api-wire": "python eval/test_api_wire.py",
    "test:auth": "node eval/test_supabase_auth.mjs",
    "mcp:supabase": "npx ts-node lib/mcp/supabase-mcp.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.106.2",
    "@types/katex": "^0.16.8",
    "@types/react-plotly.js": "^2.6.4",
    "@types/recharts": "^1.8.29",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "desmos": "^1.5.4",
    "jszip": "^3.10.1",
    "katex": "^0.16.47",
    "lucide-react": "^1.16.0",
    "mafs": "^0.21.0",
    "mammoth": "^1.12.0",
    "mathjax-react": "^2.0.1",
    "next": "16.2.6",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "plotly.js": "^3.5.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-katex": "^3.1.0",
    "react-plotly.js": "^2.6.0",
    "recharts": "^3.8.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.41",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-katex": "^3.0.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "commonjs",
      "moduleResolution": "node"
    }
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
